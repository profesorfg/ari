<details class="detallescard">
  <summary class="sumario">
    <div class="summary-grid">
      <h2 class="titulo-summary">Grúa</h2>

      <img src="ruta/imagen.png"
           alt="Foto de grúa"
           class="foto-summary">
    </div>
  </summary>

  <!-- Contenido interno -->
  <h3>Grúa</h3>
  <!-- resto del contenido -->
</details>



.summary-grid {
  display: flex;
  justify-content: space-between; /* título a la izquierda, foto a la derecha */
  align-items: center;
  width: 100%;
}

.titulo-summary {
  margin: 0;
  font-size: 1.5rem;
}

.foto-summary {
  width: 60px;   /* ajusta tamaño */
  height: 60px;
  object-fit: cover;
  border-radius: 6px; /* opcional */
}
